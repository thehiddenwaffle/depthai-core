diff --git a/src/shared/XLinkData.c b/src/shared/XLinkData.c
index 1131622..6f111f6 100644
--- a/src/shared/XLinkData.c
+++ b/src/shared/XLinkData.c
@@ -644,6 +644,18 @@ XLinkError_t addEventTimeout(xLinkEvent_t *event, struct timespec abstime)
     }
 
     if (DispatcherWaitEventCompleteTimeout(&event->deviceHandle, abstime)) {
+        if(event->header.type == XLINK_READ_REQ) {
+            streamDesc_t* stream = getStreamById(event->deviceHandle.xLinkFD,
+                                                 event->header.streamId);
+            if(stream != NULL) {
+                /*
+                 * Timed local reads can block in the dispatcher if no packet is available.
+                 * On timeout, explicitly serve the blocked request so the queue slot is
+                 * reclaimed. This mirrors the cleanup logic already present in addEvent_().
+                 */
+                DispatcherServeEvent(event->header.id, XLINK_READ_REQ, stream->id, event->deviceHandle.xLinkFD);
+                releaseStream(stream);
+            }
+        }
         return X_LINK_TIMEOUT;
     }
 
